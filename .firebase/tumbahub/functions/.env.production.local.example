# Production Firebase Configuration
# Copy this to .env.production.local and fill in your production Firebase credentials

# Firebase Client (Public - safe to commit, but use .env.production.local)
NEXT_PUBLIC_FIREBASE_API_KEY=your_prod_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tumbahub-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tumbahub-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tumbahub-prod.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_prod_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_prod_app_id_here

# Firebase Admin (Server-side only - KEEP SECURE!)
FIREBASE_PROJECT_ID=tumbahub-prod
FIREBASE_STORAGE_BUCKET=tumbahub-prod.appspot.com
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...} # Full JSON key as string

# NextAuth Configuration (use different secret for prod!)
NEXTAUTH_SECRET=your_unique_production_secret_here_min_32_chars
NEXTAUTH_URL=https://yourdomain.com  # Your production domain when deployed

# Optional: Monitoring/Logging
NEXT_PUBLIC_LOG_LEVEL=error
